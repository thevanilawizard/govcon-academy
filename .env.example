NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional alias for newer Supabase publishable keys:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=

# SAM.gov Opportunities API — users can also enter their own key in the app (stored locally)
# Get a free key at https://api.sam.gov
SAMGOV_API_KEY=

# Optional: server-side fallback for USAJobs API (users can also use sample listings without a key)
# Register at https://developer.usajobs.gov
USAJOBS_API_KEY=

# USASpending.gov public API requires no key
